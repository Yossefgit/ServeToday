<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F4FF"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="32dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/textAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Serve Today"
                android:textColor="#3C246B"
                android:textSize="34sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imageMainBanner"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginTop="18dp"
                android:adjustViewBounds="true"
                android:contentDescription="Serve Today main image"
                android:scaleType="fitCenter"
                android:src="@drawable/servetoday1" />

            <TextView
                android:id="@+id/textWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Welcome to Serve Today"
                android:textColor="#5A3E8B"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textMission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:lineSpacingExtra="6dp"
                android:text="Our mission is to help people find local volunteer events in their community. Search by zip code, explore opportunities nearby, and make a meaningful impact."
                android:textColor="#4E4E4E"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/textTagline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="Find an event. Sign up. Serve your community."
                android:textColor="#7A5DB0"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonShowEvents"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="36dp"
                android:backgroundTint="#7E57C2"
                android:text="Show Events"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>